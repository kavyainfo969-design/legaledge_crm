# ── LegalEdge Backend Environment Variables ──────────────────────────────────

# ── SMTP Email (Gmail) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=replace-with-email-username
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=replace-with-from-email
EMAIL_TIMEOUT=20

# ── App Settings ──────────────────────────────────────────────────────────────
# CHANGE 1: Generate a new key with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-secret-key

# CHANGE 2: Keep True during development
DJANGO_DEBUG=False

CRM_ALLOW_ANY=False
# Include Render backend hostname so Django serves requests to that domain
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,legaledge-crm-backend.onrender.com
FRONTEND_URL=https://legaledge-crm-frontend.onrender.com
# Public backend URL (used by frontend or other services)
BACKEND_URL=https://legaledge-crm-backend.onrender.com
STATIC_ROOT=staticfiles

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=

# ── Frontend Redirects ────────────────────────────────────────────────────────
EMAIL_OAUTH_SUCCESS_REDIRECT=https://legaledge-crm-frontend.onrender.com/settings
EMAIL_OAUTH_ERROR_REDIRECT=https://legaledge-crm-frontend.onrender.com/settings

# ── Optional Token Encryption ─────────────────────────────────────────────────
EMAIL_TOKEN_ENCRYPTION_KEY=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_ENGINE=postgres
DB_NAME=legaledge_crm
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=0
